# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=your-secret-key-here-generate-with-secrets-token-hex

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/attendance_db
# For MongoDB Atlas: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/attendance_db

# Upload Configuration
UPLOAD_FOLDER=/var/www/attendance_system/static/uploads

# ML Configuration
ML_CONFIDENCE_THRESHOLD=0.3
FACE_ENROLLMENT_COUNT=5

# Session Security
SESSION_COOKIE_SECURE=True

# Optional: Sentry Error Tracking
# SENTRY_DSN=your-sentry-dsn-here

# Optional: Email Configuration (for notifications)
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password

# Optional: Redis (for caching/sessions)
# REDIS_URL=redis://localhost:6379/0

# Application Port (for deployment)
PORT=8000
